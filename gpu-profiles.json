  "quirk_descriptions": {
    "driver_572_crash": "NVIDIA driver 572.xx crashes with RTX 30/40 series on WebGPU. Update to 573+.",
    "adreno_split_cmd_buffer": "Dawn splits command buffers between render and compute passes on Adreno. Use separate submits.",
    "adreno_no_f16_buffers": "Adreno lacks uniformAndStorageBuffer16BitAccess. shader-f16 unavailable in WebGPU.",
    "adreno_fp16_clamp": "Clamp values to <65000 before writing rgba16float storage textures.",
    "adreno_pow_guard": "pow(0,0) or pow(neg, frac) may crash. Always use max(0, base).",
    "adreno_small_l2": "256KB L2 cache. Storage buffers bypass L1. Minimize random access.",
    "metal_backend": "WebGPU uses Metal backend on Apple. Some Vulkan-specific features unavailable.",
    "intel_different_wave": "Intel Arc uses EU-level SIMD16, different from NVIDIA/AMD wave semantics.",
    "intel_low_bandwidth": "Integrated Intel has limited memory bandwidth. Reduce texture sizes.",
    "mali_small_wave": "Mali uses SIMD16 waves. Smaller workgroups may perform better.",
    "xclipse_rdna2_mobile": "Samsung Xclipse is RDNA2 but with mobile power/thermal limits."
  }
