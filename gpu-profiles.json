      "texSize": 1024,
      "displayCap": 1440,
      "waveSize": 32,
      "hwRT": true,
      "f16": true,
      "maxStorageBuffers": 10,
      "shadowRays": 2,
      "checkerboard": false,
      "quirks": [
        "driver_572_crash"
      ],
      "denoisePasses": 5
    },
