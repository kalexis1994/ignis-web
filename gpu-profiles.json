{
  "_version": 2,
  "_note": "GPU profiles for ignis-web renderer. Match by vendor+architecture from adapter.info.",
  "defaults": {
    "fsrMode": "balanced",
    "maxBounces": 2,
    "spp": 1,
    "texSize": 512,
    "denoise": "full",
    "sharc": true,
    "checkerboard": true,
    "workgroupSize": 64,
    "shadowRays": 2,
    "denoisePasses": 3,
    "displayCap": 1080,
    "waveSize": 32,
    "hwRT": false,
    "f16": false,
    "maxStorageBuffers": 8,
    "maxStorageTextures": 4,
    "quirks": []
  },
